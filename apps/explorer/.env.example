VITE_BACKEND_URL=
VITE_NODE_URL=
VITE_NETWORK_TYPE=testnet
# Optional: Alphscan API URL for normalized events (default: https://api.alphscan.io)
VITE_ALPHSCAN_API_URL=
# Required: Alphscan API key for normalized events
VITE_ALPHSCAN_API_KEY=
# Required: Alphscan API stage (e.g. dev, prod) - used in URL path
VITE_ALPHSCAN_API_STAGE=
# Optional: public explorer web base for normalized-event links (defaults to current origin). Not the Explorer API.
# VITE_ALPHSCAN_EXPLORER_URL=http://localhost:5173
# Optional: Elexium EX — NFT trait "Amount" row shows [logo] value [symbol] (logo URL; symbol defaults to EX)
# VITE_EX_TOKEN_LOGO_URI=
# VITE_EX_TOKEN_SYMBOL=EX
